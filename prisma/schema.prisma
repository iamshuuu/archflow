generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Organization ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  // Settings — Organization Info
  address              String @default("")
  website              String @default("")
  phone                String @default("")
  email                String @default("")
  logoUrl              String @default("")
  clientEmailSignature String @default("")

  // Settings — Regional Preferences
  timezone          String @default("America/New_York")
  locale            String @default("en-US")
  currency          String @default("USD")
  unitOfMeasurement String @default("feet") // feet | meters

  // Settings — Financial Configuration
  overheadCosts       Float @default(0)
  workingHoursPerYear Int   @default(2087)
  targetUtilization   Float @default(75)
  targetRealization   Float @default(65)

  // Settings — Permissions (JSON maps role -> feature -> boolean)
  permissionsJson String @default("{}")

  users              User[]
  clients            Client[]
  projects           Project[]
  invoices           Invoice[]
  invoiceTemplates   InvoiceTemplate[]
  projectTemplates   ProjectTemplate[]
  proposals          Proposal[]
  timeOffPolicies    TimeOffPolicy[]
  holidays           Holiday[]
  defaultRoles       DefaultRole[]
  consultants        Consultant[]
  consultantBills    ConsultantBill[]
  payments           Payment[]
}

// ─── Time Off Policy ───

model TimeOffPolicy {
  id          String @id @default(cuid())
  name        String // e.g. "Annual PTO", "Sick Leave"
  type        String @default("pto") // pto | sick | personal | other
  daysPerYear Float  @default(0)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Holiday ───

model Holiday {
  id   String @id @default(cuid())
  name String // e.g. "Independence Day"
  date String // YYYY-MM-DD

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Default Role (billing rates) ───

model DefaultRole {
  id              String @id @default(cuid())
  name            String // e.g. "Principal", "Project Manager", "Intern"
  defaultBillRate Float  @default(0)
  defaultCostRate Float  @default(0)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── User ───

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("member") // owner | admin | manager | member
  title        String   @default("")
  phone        String   @default("")
  costRate     Float    @default(0)
  billRate     Float    @default(0)
  targetUtil   Float    @default(75)
  createdAt    DateTime @default(now())

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  timeEntries            TimeEntry[]
  notifications          Notification[]
  expenses               Expense[]
  allocations            Allocation[]
  phaseAssignments       PhaseAssignment[]
  tasks                  Task[]
  timeOffRequests        TimeOffRequest[]
  timesheetSubmissions   TimesheetSubmission[]
  deliverables           Deliverable[]
  uploadedFiles          ProjectFile[]
}

// ─── Client ───

model Client {
  id          String @id @default(cuid())
  name        String
  email       String @default("")
  phone       String @default("")
  address     String @default("")
  website     String @default("")
  notes       String @default("")
  industry    String @default("")
  status      String @default("active") // active | inactive | prospect
  contactName String @default("")
  createdAt   DateTime @default(now())

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  projects  Project[]
  invoices  Invoice[]
  proposals Proposal[]
}

// ─── Proposal ───

model Proposal {
  id          String   @id @default(cuid())
  title       String
  amount      Float    @default(0)
  status      String   @default("draft") // draft | sent | accepted | declined
  sentDate    String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Project ───

model Project {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("Commercial")
  status        String   @default("active") // active | pipeline | on-hold | completed | archived
  phase         String   @default("")
  progress      Int      @default(0)
  contractValue Float    @default(0)
  startDate      String   @default("")
  endDate        String   @default("")
  pipelineStage  String   @default("lead") // lead | proposal | negotiation | won | lost
  createdAt      DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  templateId String?

  phases          Phase[]
  timeEntries     TimeEntry[]
  invoices        Invoice[]
  notifications   Notification[]
  milestones      Milestone[]
  expenses        Expense[]
  allocations     Allocation[]
  tasks           Task[]
  consultantBills ConsultantBill[]
  files           ProjectFile[]
  deliverables    Deliverable[]
}

// ─── Phase ───

model Phase {
  id           String @id @default(cuid())
  name         String
  budgetHours  Float  @default(0)
  budgetAmount Float  @default(0)
  feeType      String @default("hourly") // hourly | fixed | not-to-exceed
  startDate    String @default("") // YYYY-MM-DD
  endDate      String @default("") // YYYY-MM-DD
  color        String @default("") // hex color for Gantt bar

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  timeEntries   TimeEntry[]
  milestones    Milestone[]
  assignments   PhaseAssignment[]
  tasks         Task[]
  deliverables  Deliverable[]
  files         ProjectFile[]
}

model PhaseAssignment {
  id           String   @id @default(cuid())
  roleLabel    String   @default("")
  plannedHours Float    @default(0)
  createdAt    DateTime @default(now())

  phaseId String
  phase   Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([phaseId, userId])
}

// ─── Milestone ───

model Milestone {
  id   String  @id @default(cuid())
  name String
  date String  // YYYY-MM-DD
  done Boolean @default(false)

  phaseId String
  phase   Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])
}

// ─── Time Entry ───

model TimeEntry {
  id           String  @id @default(cuid())
  date         String  // YYYY-MM-DD
  hours        Float
  notes        String  @default("")
  status       String  @default("draft") // draft | submitted | approved
  billable     Boolean @default(true)
  entryType    String  @default("regular") // regular | pto | holiday | admin
  activityType String  @default("design") // design | project-mgmt | site-visit | meeting | admin | other

  userId String
  user   User @relation(fields: [userId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  phaseId String
  phase   Phase @relation(fields: [phaseId], references: [id])
}

// ─── Time Off Request ───

model TimeOffRequest {
  id         String   @id @default(cuid())
  type       String   @default("pto") // pto | sick | personal | other
  startDate  String   // YYYY-MM-DD
  endDate    String   // YYYY-MM-DD
  hours      Float    @default(8)
  status     String   @default("pending") // pending | approved | rejected
  notes      String   @default("")
  reviewedBy String   @default("")
  reviewedAt String   @default("")
  createdAt  DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  orgId String
}

// ─── Timesheet Submission ───

model TimesheetSubmission {
  id          String   @id @default(cuid())
  week        String   // ISO week e.g. "2025-W08"
  status      String   @default("draft") // draft | submitted | approved | rejected
  totalHours  Float    @default(0)
  submittedAt String   @default("")
  reviewedBy  String   @default("")
  reviewedAt  String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  orgId String
}

// ─── Invoice ───

model Invoice {
  id           String @id @default(cuid())
  number       String @unique
  amount       Float  @default(0)
  date         String
  dueDate      String
  status       String @default("draft") // draft | sent | viewed | paid | overdue
  notes        String @default("") // freeform notes on the invoice
  paymentUrl   String @default("") // Stripe/PayPal link
  paymentTerms String @default("net30") // net15 | net30 | net45 | net60 | custom

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  lineItems InvoiceLineItem[]
  payments  Payment[]
}

// ─── Invoice Template ───

model InvoiceTemplate {
  id          String @id @default(cuid())
  name        String @default("Default")
  logo        String @default("") // URL or base64
  companyName String @default("")
  address     String @default("")
  phone       String @default("")
  email       String @default("")
  headerText  String @default("")
  footerText  String @default("Payment is due within 30 days.")
  accentColor String @default("#B07A4A")
  isDefault   Boolean @default(false)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Invoice Line Item ───

model InvoiceLineItem {
  id          String @id @default(cuid())
  description String
  qty         Float
  rate        Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─── Payment ───

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  date      String   // YYYY-MM-DD
  method    String   @default("check") // check | ach | wire | credit_card | cash | other
  reference String   @default("") // check number, transaction ID, etc.
  notes     String   @default("")
  createdAt DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Consultant ───

model Consultant {
  id        String   @id @default(cuid())
  name      String
  company   String   @default("")
  email     String   @default("")
  phone     String   @default("")
  specialty String   @default("")
  markupPct Float    @default(0)
  status    String   @default("active") // active | inactive
  createdAt DateTime @default(now())

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  bills ConsultantBill[]
}

// ─── Consultant Bill ───

model ConsultantBill {
  id          String   @id @default(cuid())
  amount      Float
  date        String   // YYYY-MM-DD
  description String   @default("")
  invoiceRef  String   @default("") // consultant's own invoice number
  status      String   @default("pending") // pending | approved | paid
  createdAt   DateTime @default(now())

  consultantId String
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Notification ───

model Notification {
  id        String   @id @default(cuid())
  type      String   @default("budget_alert") // budget_alert | budget_warning | budget_critical | info
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
}

// ─── Expense ───

model Expense {
  id          String   @id @default(cuid())
  category    String   @default("other") // travel | meals | materials | software | mileage | other
  description String
  amount      Float
  date        String   // YYYY-MM-DD
  receipt     String   @default("") // file path or URL
  billable    Boolean  @default(true)
  status      String   @default("pending") // pending | approved | rejected | reimbursed
  mileage     Float    @default(0) // miles driven (for mileage category)
  mileageRate Float    @default(0.67) // IRS rate per mile
  notes       String   @default("")
  createdAt   DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  phaseId String?
}

// ─── Allocation ───

model Allocation {
  id           String @id @default(cuid())
  week         String // YYYY-Www (ISO week), e.g. "2026-W09"
  plannedHours Float  @default(0)

  userId String
  user   User @relation(fields: [userId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId, week])
}

// ─── Project Template ───

model ProjectTemplate {
  id             String @id @default(cuid())
  name           String
  description    String @default("")
  defaultPhases  String @default("[]") // JSON array of phase names
  defaultType    String @default("Commercial")

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])
}

// ─── Task ───

model Task {
  id        String @id @default(cuid())
  title     String
  status    String @default("todo") // todo | in-progress | review | done
  dueDate   String @default("")
  sortOrder Int    @default(0)

  phaseId String
  phase   Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User? @relation(fields: [assigneeId], references: [id])
}

// ─── Project File ───

model ProjectFile {
  id        String   @id @default(cuid())
  name      String
  url       String   @default("")
  fileType  String   @default("other") // drawing | contract | spec | photo | report | other
  size      Int      @default(0) // bytes
  createdAt DateTime @default(now())

  uploadedById String
  uploadedBy   User @relation(fields: [uploadedById], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  phaseId String?
  phase   Phase? @relation(fields: [phaseId], references: [id])

  orgId String
}

// ─── Deliverable ───

model Deliverable {
  id            String   @id @default(cuid())
  title         String
  description   String   @default("")
  status        String   @default("pending") // pending | in-progress | completed | approved
  dueDate       String   @default("")
  completedDate String   @default("")
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  phaseId String
  phase   Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User? @relation(fields: [assigneeId], references: [id])
}
